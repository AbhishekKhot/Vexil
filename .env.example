# ---------------------------------------------------------------------------
# Vexil — Docker Compose environment variables
#
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# docker-compose.yml reads variables from this .env file automatically.
# Variables with :-default syntax are optional; the default is used if unset.
# Variables with :? syntax are REQUIRED — Compose will refuse to start without them.
# ---------------------------------------------------------------------------

# ── Required ────────────────────────────────────────────────────────────────

# JWT signing secret — MUST be set to a strong random value in production.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# ── PostgreSQL (optional — defaults match docker-compose service) ────────────
DB_USER=postgres
DB_PASS=postgres
DB_NAME=vexil
DB_PORT=5432

# ── Redis (optional — defaults match docker-compose service) ─────────────────
REDIS_PORT=6379

# ── CORS (optional) ──────────────────────────────────────────────────────────
# URL from which the browser loads the web dashboard.
# If you expose the web on a different host/port, update this.
WEB_URL=http://localhost:5173

# ── Web build (optional) ──────────────────────────────────────────────────────
# The API URL that gets baked into the web JS bundle at build time.
# From the browser's perspective — use the host-facing address.
VITE_API_URL=http://localhost:3000

# ── Rate-limit tuning (optional) ─────────────────────────────────────────────
# Raise these if you need higher throughput without redeploying.
MAX_EVAL_PER_DAY=5000       # SDK evaluate calls per API key per day
EVAL_BUCKET_CAPACITY=20     # Token-bucket burst size per API key
EVAL_REFILL_RATE_MS=500     # One token added every N ms (500 = 2 req/s steady)
