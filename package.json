{
  "name": "vexil",
  "version": "1.0.0",
  "description": "High-performance, open-source feature flag service with local evaluation and deterministic rollouts.",
  "private": true,
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:sdk": "npm run build --workspace=packages/sdk-js",
    "build": "npm run build:sdk && npm run build:api && npm run build:web"
  },
  "keywords": ["feature-flags", "feature-toggles", "remote-config"],
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
