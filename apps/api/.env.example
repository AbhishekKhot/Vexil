PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=vexil

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Auth — REQUIRED. Server refuses to start without this.
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# CORS — origin allowed to call this API (dashboard URL)
WEB_URL=http://localhost:5173

# Rate limit tuning (data plane) — raise these for demos without redeploying
MAX_EVAL_PER_DAY=100       # max SDK evaluate calls per API key per day
EVAL_BUCKET_CAPACITY=5     # token bucket burst size per API key
EVAL_REFILL_RATE_MS=2000   # one token added every N ms (2000 = 0.5 req/s)
