{
  "getLogs": {
    "tags": ["Audit Logs"],
    "summary": "List audit log entries for a project",
    "security": [{ "bearerAuth": [] }],
    "querystring": {
      "type": "object",
      "properties": {
        "page": {
          "type": "string",
          "description": "1-based page number (default: 1)."
        },
        "limit": {
          "type": "string",
          "description": "Items per page, max 100 (default: 20)."
        },
        "action": {
          "type": "string",
          "description": "Filter by action verb (e.g. created, updated, deleted)."
        },
        "entityType": {
          "type": "string",
          "description": "Filter by entity kind (e.g. flag, environment, segment)."
        }
      }
    }
  },

  "getLogById": {
    "tags": ["Audit Logs"],
    "summary": "Get a single audit log entry by ID",
    "security": [{ "bearerAuth": [] }]
  }
}
